{
  "name": "interviewqa-solution",
  "version": "1.0.0",
  "description": "ใช้ playwright",
  "main": "index.js",
  "scripts": {
    "test:ui": "cucumber-js -p ui",
    "posttest:ui": "npm run report",
    "test:headed": "cross-env HEADED=true cucumber-js -p ui",
    "posttest:headed": "npm run report",
    "test:login": "cucumber-js --tags @login",
    "posttest:login": "npm run report",
    "test:shop": "cucumber-js --tags @shop",
    "posttest:shop": "npm run report",
    "test:checkout": "cucumber-js --tags @checkout",
    "posttest:checkout": "npm run report",
    "test:confirmation": "cucumber-js --tags @confirmation",
    "posttest:confirmation": "npm run report",
    "report": "ts-node utils/report.ts"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "typescript",
    "bdd",
    "qa-automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0",
    "playwright": "^1.61.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
